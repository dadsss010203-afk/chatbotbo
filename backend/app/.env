# ─────────────────────────────────────────────
#  ChatbotBO — Variables de entorno
#  Copia este archivo y ajusta los valores
# ─────────────────────────────────────────────

# ── Flask
FLASK_SECRET_KEY=correos-agbc-2026-secreto
PORT=5000
DEBUG=false

# ── Ollama
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_TIMEOUT=600
LLM_MODEL=correos-bot

# ── Embeddings (modelo multilingüe ligero)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Token de Hugging Face (opcional pero recomendado)
# si defines HF_TOKEN, las descargas de modelos serán autenticadas y
# el proyecto evitará warnings al subir modelos al Hub.
#HF_TOKEN=

# ── ChromaDB (BD vectorial)
CHROMA_PATH=chroma_db

# ── Archivos de data (generados por el scraper)
DATA_FILE=data/correos_bolivia.txt
SUCURSALES_FILE=data/sucursales_contacto.json
SECCIONES_FILE=data/secciones_home.json

# ── RAG
CHUNK_SIZE=600
BATCH_SIZE=500
N_RESULTADOS=3

# ── Sesiones
MAX_HISTORIAL=6

# ── Actualización automática del scraper
HORAS_ACTUALIZACION=24
